{
  "manifest_version": 3,
  "name": "Lazada Order PDF Downloader",
  "version": "2.3",
  "description": "Bulk download Lazada order detail pages as PDFs with date filtering, status filtering, and clean PDF output",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "debugger",
    "downloads",
    "downloads.ui",
    "sidePanel"
  ],
  "host_permissions": [
    "https://my.lazada.co.th/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://my.lazada.co.th/customer/order/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
